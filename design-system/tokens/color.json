{
  "$extensions": {
    "ds.modeType": "theme",
    "ds.defaultMode": "light",
    "ds.modes": [
      "light"
    ]
  },
  "$description": "SNAP semantic color, extracted from the Figma 'color' collection. Components use ONLY these semantic tokens (never primitives). SNAP defines a single 'light' mode in Figma — there is no dark/wireframe theme in the source, so none is emitted. The 'theme' modeType is kept so theme overrides can be added under $extensions['ds.modes'] if SNAP adds modes later. Keep the Tailwind color map (tailwind.config.js) in sync with these groups.",
  "background": {
    "$type": "color",
    "default": {
      "$value": "{color.gray.gray}"
    },
    "surface": {
      "$description": "Cards, sheets, raised surfaces.",
      "$value": "{color.white.white}"
    },
    "inverse": {
      "$value": "{color.blue.impactful}"
    },
    "overlay": {
      "$value": "{color.ink.12}"
    },
    "overlay-strong": {
      "$value": "{color.ink.40}"
    },
    "accent-1": {
      "$value": "{color.blue.impactful}"
    },
    "accent-2": {
      "$value": "{color.blue.bright}"
    },
    "info": {
      "$value": "{color.blue.optimistic}"
    },
    "positive": {
      "$value": "{color.green.optimistic}"
    },
    "negative": {
      "$value": "{color.red.optimistic}"
    },
    "disabled": {
      "$value": "{color.ink.12}"
    },
    "interactive-primary": {
      "$description": "Primary action fill (resting).",
      "$value": "{color.blue.impactful}"
    },
    "interactive-primary-hovered": {
      "$description": "Primary action fill on hover/press — pair with text/default.",
      "$value": "{color.blue.bright}"
    },
    "interactive-accent": {
      "$value": "{color.red.insightful}"
    },
    "interactive-negative": {
      "$value": "{color.red.insightful}"
    },
    "interactive-negative-hovered": {
      "$value": "{color.red.impactful}"
    }
  },
  "border": {
    "$type": "color",
    "default": {
      "$value": "{color.ink.20}"
    },
    "subtle": {
      "$value": "{color.ink.12}"
    },
    "input": {
      "$value": "{color.ink.40}"
    },
    "strong": {
      "$value": "{color.ink.90}"
    },
    "inverse": {
      "$value": "{color.white.20}"
    },
    "info": {
      "$value": "{color.blue.insightful}"
    },
    "positive": {
      "$value": "{color.green.insightful}"
    },
    "negative": {
      "$value": "{color.red.insightful}"
    },
    "disabled": {
      "$value": "{color.ink.20}"
    },
    "interactive-accent": {
      "$value": "{color.red.insightful}"
    },
    "focus": {
      "$description": "Focus ring color. Drives --shadow-focus.",
      "$value": "{color.blue.bold}"
    }
  },
  "text": {
    "$type": "color",
    "default": {
      "$value": "{color.ink.100}"
    },
    "secondary": {
      "$value": "{color.ink.60}"
    },
    "inverse": {
      "$value": "{color.white.white}"
    },
    "accent-1": {
      "$value": "{color.blue.bright}"
    },
    "accent-2": {
      "$value": "{color.blue.impactful}"
    },
    "info": {
      "$value": "{color.blue.insightful}"
    },
    "positive": {
      "$value": "{color.green.insightful}"
    },
    "negative": {
      "$value": "{color.red.insightful}"
    },
    "disabled": {
      "$value": "{color.ink.60}"
    },
    "interactive-accent": {
      "$value": "{color.red.insightful}"
    },
    "interactive-accent-hovered": {
      "$value": "{color.red.impactful}"
    }
  }
}
