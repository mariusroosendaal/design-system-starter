{
  "$description": "EXAMPLE primitives — replace these with the values extracted from your client's Figma file (variable collections). Primitives are raw, context-free values; components never use them directly (they go through the semantic tokens in color.json / dimension.json / typography.json).",
  "color": {
    "$type": "color",
    "white": {
      "white": { "$value": "#ffffff" },
      "8": { "$value": "#ffffff14" },
      "12": { "$value": "#ffffff1f" }
    },
    "black": {
      "black": { "$value": "#000000" },
      "8": { "$value": "#00000014" },
      "12": { "$value": "#0000001f" }
    },
    "neutral": {
      "50": { "$value": "#f7f7f7" },
      "100": { "$value": "#e6e6e6" },
      "300": { "$value": "#c2c2c2" },
      "500": { "$value": "#737373" },
      "700": { "$value": "#404040" },
      "900": { "$value": "#171717" },
      "950": { "$value": "#0a0a0a" }
    },
    "accent": {
      "100": { "$value": "#dbeafe" },
      "400": { "$value": "#60a5fa" },
      "500": { "$value": "#2563eb" },
      "600": { "$value": "#1d4ed8" }
    }
  },
  "size": {
    "$type": "dimension",
    "4": { "$value": "4px" },
    "8": { "$value": "8px" },
    "12": { "$value": "12px" },
    "16": { "$value": "16px" },
    "24": { "$value": "24px" },
    "32": { "$value": "32px" },
    "36": { "$value": "36px" },
    "40": { "$value": "40px" },
    "48": { "$value": "48px" },
    "64": { "$value": "64px" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "full": { "$value": "9999px" }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "$description": "Full CSS stacks (first family is the brand face; rest are fallbacks). The example uses a system stack so it renders with no bundled fonts.",
    "sans": { "$value": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" },
    "mono": { "$value": "ui-monospace, SFMono-Regular, Menlo, monospace" }
  },
  "fontSize": {
    "$type": "dimension",
    "12": { "$value": "12px" },
    "14": { "$value": "14px" },
    "16": { "$value": "16px" },
    "20": { "$value": "20px" },
    "24": { "$value": "24px" },
    "32": { "$value": "32px" }
  }
}
