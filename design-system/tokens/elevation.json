{
  "$description": "SNAP elevation, extracted from the Figma effect styles (shadow-sm, shadow-md, .focus). 'focus' is the focus ring — apply on :focus-visible. Shadow tints are raw rgba (not palette tokens); the focus ring color is the semantic border/focus token.",
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "color": "#0000000d",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "1px"
      }
    },
    "md": {
      "$value": [
        {
          "color": "#0000004d",
          "offsetX": "0px",
          "offsetY": "0px",
          "blur": "2px",
          "spread": "0px"
        },
        {
          "color": "#00000014",
          "offsetX": "0px",
          "offsetY": "3px",
          "blur": "3px",
          "spread": "0px"
        }
      ]
    },
    "focus": {
      "$value": {
        "color": "{border.focus}",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "2px"
      }
    }
  }
}
