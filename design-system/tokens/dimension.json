{
  "$extensions": {
    "ds.modeType": "breakpoint",
    "ds.defaultMode": "sm",
    "ds.modes": [
      "sm",
      "md",
      "lg",
      "xl",
      "2xl"
    ]
  },
  "$description": "SNAP semantic dimensions, extracted from the Figma 'responsive' collection. Tokens are responsive: top-level $value is the smallest breakpoint (sm), the rest live under $extensions['ds.modes'] keyed by breakpoint (min-width). 'breakpoint/*' is the single source of truth for min-widths (build.mjs and tailwind.config.js both derive from it). 'space/*' is the spacing scale (padding/gap/margin); it scales up at larger breakpoints. Replace/extend to match the grid.",
  "breakpoint": {
    "$type": "dimension",
    "sm": {
      "$value": "0px"
    },
    "md": {
      "$value": "600px"
    },
    "lg": {
      "$value": "900px"
    },
    "xl": {
      "$value": "1200px"
    },
    "2xl": {
      "$value": "1500px"
    }
  },
  "layout": {
    "$type": "dimension",
    "viewport-width": {
      "$extensions": {
        "ds.modes": {
          "md": "768px",
          "lg": "1024px",
          "xl": "1440px",
          "2xl": "1920px"
        }
      },
      "$value": "400px"
    },
    "viewport-height": {
      "$extensions": {
        "ds.modes": {
          "md": "1024px",
          "lg": "768px",
          "xl": "850px",
          "2xl": "1080px"
        }
      },
      "$value": "840px"
    },
    "columns": {
      "$value": 12
    },
    "gutter": {
      "$extensions": {
        "ds.modes": {
          "md": "24px",
          "2xl": "32px"
        }
      },
      "$value": "16px"
    },
    "margin": {
      "$extensions": {
        "ds.modes": {
          "md": "24px",
          "2xl": "32px"
        }
      },
      "$value": "16px"
    }
  },
  "space": {
    "1": {
      "$value": "{size.4}"
    },
    "2": {
      "$value": "{size.8}"
    },
    "3": {
      "$extensions": {
        "ds.modes": {
          "2xl": "{size.16}"
        }
      },
      "$value": "{size.12}"
    },
    "4": {
      "$extensions": {
        "ds.modes": {
          "lg": "{size.16}",
          "2xl": "{size.24}"
        }
      },
      "$value": "{size.12}"
    },
    "5": {
      "$extensions": {
        "ds.modes": {
          "lg": "{size.24}",
          "2xl": "{size.32}"
        }
      },
      "$value": "{size.16}"
    },
    "6": {
      "$extensions": {
        "ds.modes": {
          "lg": "{size.32}",
          "2xl": "{size.40}"
        }
      },
      "$value": "{size.24}"
    },
    "7": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.32}",
          "lg": "{size.40}",
          "2xl": "{size.48}"
        }
      },
      "$value": "{size.24}"
    },
    "8": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.40}",
          "lg": "{size.48}",
          "2xl": "{size.64}"
        }
      },
      "$value": "{size.32}"
    },
    "9": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.48}",
          "lg": "{size.64}",
          "2xl": "{size.80}"
        }
      },
      "$value": "{size.40}"
    },
    "10": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.64}",
          "lg": "{size.80}",
          "2xl": "{size.96}"
        }
      },
      "$value": "{size.48}"
    },
    "11": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.80}",
          "lg": "{size.96}",
          "2xl": "{size.128}"
        }
      },
      "$value": "{size.64}"
    },
    "12": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.96}",
          "lg": "{size.128}",
          "2xl": "{size.160}"
        }
      },
      "$value": "{size.80}"
    },
    "13": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.128}",
          "lg": "{size.160}",
          "2xl": "{size.192}"
        }
      },
      "$value": "{size.96}"
    },
    "14": {
      "$extensions": {
        "ds.modes": {
          "md": "{size.160}",
          "lg": "{size.192}",
          "2xl": "{size.256}"
        }
      },
      "$value": "{size.128}"
    },
    "$type": "dimension"
  },
  "content-width": {
    "$type": "dimension",
    "narrow": {
      "$extensions": {
        "ds.modes": {
          "md": "596px",
          "lg": "640px",
          "xl": "684px",
          "2xl": "910px"
        }
      },
      "$value": "368px"
    },
    "standard": {
      "$extensions": {
        "ds.modes": {
          "md": "720px",
          "lg": "806px",
          "xl": "1156px",
          "2xl": "1538px"
        }
      },
      "$value": "368px"
    },
    "wide": {
      "$extensions": {
        "ds.modes": {
          "md": "720px",
          "lg": "972px",
          "xl": "1392px",
          "2xl": "1852px"
        }
      },
      "$value": "368px"
    }
  },
  "interactive": {
    "$type": "dimension",
    "height-sm": {
      "$value": "{size.40}"
    },
    "height-md": {
      "$value": "{size.48}"
    }
  }
}
